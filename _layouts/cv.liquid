---
layout: default
---

{% assign cv_pdf_url = nil %}
{% if page.cv_pdf %}
  {% if page.cv_pdf contains '://' %}
    {% assign cv_pdf_url = page.cv_pdf %}
  {% elsif page.cv_pdf contains '/' %}
    {% assign cv_pdf_url = page.cv_pdf | relative_url %}
  {% else %}
    {% assign cv_pdf_url = '/assets/pdf/' | append: page.cv_pdf | relative_url %}
  {% endif %}
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if cv_pdf_url %}
        <a href="{{ cv_pdf_url }}" target="_blank" rel="noopener noreferrer" class="float-right">
          <i class="fas fa-file-pdf"></i>
        </a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    {% if cv_pdf_url and page.cv_pdf_embed != false %}
      <div class="row">
        <div class="col-12">
          <p class="text-center text-monospace mt-3">
            <a href="{{ cv_pdf_url }}" target="_blank" rel="noopener noreferrer">Download CV</a>
          </p>
        </div>
        <div class="col-12">
          <div
            id="pdf-viewer"
            style="height: {{ page.cv_pdf_height | default: 900 }}px; overflow-y: auto; overflow-x: hidden; border: 1px solid rgba(127, 127, 127, 0.3); border-radius: 0.375rem; padding: 0.5rem;"
          ></div>
        </div>
      </div>

      <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
      <script>
        document.addEventListener('DOMContentLoaded', async function () {
          if (typeof pdfjsLib === 'undefined') return;

          pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

          const viewer = document.getElementById('pdf-viewer');
          if (!viewer) return;

          try {
            const loadingTask = pdfjsLib.getDocument('{{ cv_pdf_url }}');
            const pdf = await loadingTask.promise;

            for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
              const page = await pdf.getPage(pageNum);
              const viewport = page.getViewport({ scale: 1.25 });

              const canvas = document.createElement('canvas');
              canvas.style.display = 'block';
              canvas.style.margin = '0 auto 1rem';
              canvas.style.maxWidth = '100%';
              canvas.width = viewport.width;
              canvas.height = viewport.height;

              const context = canvas.getContext('2d');
              await page.render({ canvasContext: context, viewport: viewport }).promise;

              viewer.appendChild(canvas);
            }
          } catch (error) {
            viewer.innerHTML = '<p class="text-center mt-3">Unable to render PDF in-page. Use the Download CV link above.</p>';
          }
        });
      </script>
    {% endif %}

    <div class="clearfix">
      {{ content }}
    </div>
  </article>
</div>