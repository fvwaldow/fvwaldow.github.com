---
layout: default
---

{% assign cv_pdf_url = nil %}
{% if page.cv_pdf %}
  {% if page.cv_pdf contains '://' %}
    {% assign cv_pdf_url = page.cv_pdf %}
  {% elsif page.cv_pdf contains '/' %}
    {% assign cv_pdf_url = page.cv_pdf | relative_url %}
  {% else %}
    {% assign cv_pdf_url = '/assets/pdf/' | append: page.cv_pdf | relative_url %}
  {% endif %}
{% endif %}

<div class="post">
  <article>
    {% if cv_pdf_url and page.cv_pdf_embed != false %}
      <div class="row">
        <div class="col-12">
          <p class="text-center text-monospace mt-3">
            <a href="{{ cv_pdf_url }}" target="_blank" rel="noopener noreferrer">Download CV</a>
          </p>
        </div>
        <div class="col-12">
          <div
            id="pdf-viewer"
            style="height: {{ page.cv_pdf_height | default: 900 }}px; overflow-y: auto; overflow-x: hidden; border: 1px solid rgba(127, 127, 127, 0.3); border-radius: 0.375rem; padding: 0.5rem;"
          ></div>
        </div>
      </div>

      <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
      <script>
        document.addEventListener('DOMContentLoaded', async function () {
          if (typeof pdfjsLib === 'undefined') return;

          pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

          const viewer = document.getElementById('pdf-viewer');
          if (!viewer) return;

          try {
            const loadingTask = pdfjsLib.getDocument('{{ cv_pdf_url }}');
            const pdf = await loadingTask.promise;
            const renderScale = {{ page.cv_pdf_scale | default: 1.6 }};
            const deviceScale = window.devicePixelRatio || 1;

            for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
              const page = await pdf.getPage(pageNum);
              const viewport = page.getViewport({ scale: renderScale });

              const pageContainer = document.createElement('div');
              pageContainer.style.position = 'relative';
              pageContainer.style.width = `${viewport.width}px`;
              pageContainer.style.height = `${viewport.height}px`;
              pageContainer.style.margin = '0 auto 1rem';
              pageContainer.style.maxWidth = '100%';

              const canvas = document.createElement('canvas');
              canvas.style.display = 'block';
              canvas.style.width = `${viewport.width}px`;
              canvas.style.height = `${viewport.height}px`;
              canvas.width = Math.floor(viewport.width * deviceScale);
              canvas.height = Math.floor(viewport.height * deviceScale);

              const context = canvas.getContext('2d');
              await page.render({
                canvasContext: context,
                viewport: viewport,
                transform: [deviceScale, 0, 0, deviceScale, 0, 0],
              }).promise;

              pageContainer.appendChild(canvas);

              const annotations = await page.getAnnotations();
              for (const annotation of annotations) {
                if (annotation.subtype !== 'Link') continue;

                const href = annotation.url || annotation.unsafeUrl;
                if (!href) continue;

                const rect = viewport.convertToViewportRectangle(annotation.rect);
                const left = Math.min(rect[0], rect[2]);
                const top = Math.min(rect[1], rect[3]);
                const width = Math.abs(rect[0] - rect[2]);
                const height = Math.abs(rect[1] - rect[3]);

                const link = document.createElement('a');
                link.href = href;
                link.target = '_blank';
                link.rel = 'noopener noreferrer';
                link.title = href;
                link.style.position = 'absolute';
                link.style.left = `${left}px`;
                link.style.top = `${top}px`;
                link.style.width = `${width}px`;
                link.style.height = `${height}px`;
                link.style.backgroundColor = 'rgba(5, 205, 65, 0.25)';
                link.style.outline = '1px solid rgba(0, 167, 50, 0.8)';
                link.style.borderRadius = '2px';

                pageContainer.appendChild(link);
              }

              viewer.appendChild(pageContainer);
            }
          } catch (error) {
            viewer.innerHTML = '<p class="text-center mt-3">Unable to render PDF in-page. Use the Download CV link above.</p>';
          }
        });
      </script>
    {% endif %}

    <div class="clearfix">
      {{ content }}
    </div>
  </article>
</div>